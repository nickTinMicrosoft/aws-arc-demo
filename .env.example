# AWS Credentials
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=us-east-1

# EC2 Instance Details
EC2_INSTANCE_ID=i-xxxxxxxxxxxxxxxxx
EC2_PUBLIC_IP=x.x.x.x
EC2_ADMIN_USER=Administrator
EC2_ADMIN_PASSWORD=your-windows-password

# AWS Resources
AWS_VPC_ID=vpc-xxxxxxxxxxxxxxxxx
AWS_SECURITY_GROUP_ID=sg-xxxxxxxxxxxxxxxxx
AWS_KEY_PAIR_NAME=arc-demo-key

# Azure Arc Configuration
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=arc-demo-rg
AZURE_LOCATION=eastus
AZURE_TENANT_ID=your-tenant-id
